# Clerk (client) — same value as Clerk Dashboard → API keys → Publishable key.
# Local: .env.local is git-ignored. Production: set on Vercel for **Production** → Redeploy.
# This Vite app uses VITE_ prefix (not NEXT_PUBLIC_). Optional fallback: NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=

# Firebase (client) — all six variables are required. Copy to .env locally.
# Production: Vercel → Project → Settings → Environment Variables → add each key
# for **Production** (not only Preview), then **Redeploy**. Vite inlines them at build time.
#
# Firebase Console → Project settings → Your apps → Web app config.
# Auth → Settings → Authorized domains: add your Vercel host (e.g. *.vercel.app).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
